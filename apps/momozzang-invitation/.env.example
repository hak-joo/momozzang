# 환경변수 예시. 실제 값은 커밋하지 않는다(.env 는 gitignore 대상).

# Naver map api
VITE_NAVER_MAP_CLIENT_ID=

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Data Source: 'local' | 'supabase'
VITE_DATA_SOURCE=supabase

# Image base URL: 업로드된 이미지 객체 키를 최종 URL로 조립할 때 쓰는 베이스(조회 경로).
# R2 전환 후: https://img.momozzang.com
# (invitation 앱은 조회 전용 — 업로드 키 VITE_UPLOAD_* 는 어드민에서만 사용)
VITE_IMAGE_BASE_URL=
