# 환경변수 예시. 실제 값은 커밋하지 않는다(.env 는 gitignore 대상).

# Naver map api
VITE_NAVER_MAP_CLIENT_ID=

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Data Source: 'local' | 'supabase'
VITE_DATA_SOURCE=supabase

# Image base URL: 업로드된 이미지 객체 키를 최종 URL로 조립할 때 쓰는 베이스(조회 경로).
# R2 전환 후: https://img.momozzang.com
VITE_IMAGE_BASE_URL=

# Upload (Cloudflare Worker → R2 바인딩). 조회 경로(VITE_IMAGE_BASE_URL)와 분리.
# Worker 업로드 엔드포인트 절대 URL. 예: https://api.momozzang.com/upload
# (momozzang.com/api/* 금지 — vercel.json 의 /api 프록시와 충돌)
VITE_UPLOAD_ENDPOINT=
# 어드민이 X-Upload-Token 헤더로 보낼 공유비밀.
# ⚠️ 클라이언트 노출형(Vite 가 번들에 평문 치환) 약한 1차 방어 — R2 Access Key/Secret 과 동급 아님.
VITE_UPLOAD_TOKEN=

# Kakao share
VITE_KAKAO_APP_KEY=
VITE_KAKAO_TEMPLATE_ID=
