# 환경변수 예시. 실제 값은 커밋하지 않는다(.env 는 gitignore 대상).

# Naver map api
VITE_NAVER_MAP_CLIENT_ID=

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Data Source: 'local' | 'supabase'
VITE_DATA_SOURCE=local

# Image base URL: 업로드된 이미지 객체 키를 최종 URL로 조립할 때 쓰는 베이스.
# 형식: {VITE_SUPABASE_URL}/storage/v1/object/public/wedding-images
# R2 등 스토리지/도메인 이전 시 이 값만 교체하면 된다(DB 마이그레이션 불필요).
VITE_IMAGE_BASE_URL=
